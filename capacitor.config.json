{
  "appId": "za.co.learnview.nexus",
  "appName": "LearnView Nexus",
  "webDir": "www",
  "bundledWebRuntime": false,
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1800,
      "launchAutoHide": true,
      "backgroundColor": "#FFFFFF",
      "androidSplashResourceName": "splash",
      "showSpinner": false,
      "splashFullScreen": false,
      "splashImmersive": false
    },
    "StatusBar": {
      "overlaysWebView": false,
      "style": "LIGHT",
      "backgroundColor": "#FFFFFF"
    },
    "SystemBars": {
      "insetsHandling": "css",
      "style": "LIGHT",
      "hidden": false,
      "animation": "NONE"
    }
  }
}
